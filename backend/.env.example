NODE_ENV=production
PORT=5000

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/qline
FRONTEND_URL=https://qline.yourdomain.com

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRY=15m
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_REFRESH_EXPIRY=7d
REFRESH_COOKIE_NAME=qline_rt

MEDICAL_RECORD_ENCRYPTION_KEY=replace-with-a-32-plus-character-secret

LOG_LEVEL=info
CACHE_WARM_ON_STARTUP=true
RUN_WORKERS_IN_API=false
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

FROM_EMAIL=noreply@yourdomain.com
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
ADMIN_IP_WHITELIST=
ENABLE_STARTUP_TEST_SEED=false
