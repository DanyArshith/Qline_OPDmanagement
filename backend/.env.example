# =============================================================================
# Qline Backend - Environment Variables
# Copy to .env and fill in your values
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/qline
# Docker compose uses: mongodb://mongo:27017/qline

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=                     # Uncomment if Redis requires auth
REDIS_MAX_MEMORY=256mb
REDIS_EVICTION_POLICY=allkeys-lru
REQUIRE_REDIS_IN_PRODUCTION=false     # Set true to fail-fast if Redis is down

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-at-least-64-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-different-from-jwt-secret-also-64-chars
JWT_REFRESH_EXPIRY=7d

# ── Email ─────────────────────────────────────────────────────────────────────
# Option A: SendGrid (recommended for production)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxx

# Option B: SMTP (e.g. Mailtrap for dev, Gmail for prod)
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_pass

FROM_EMAIL=noreply@qline.app
EMAIL_MAX_RETRY_ATTEMPTS=3
EMAIL_WORKER_CONCURRENCY=5
REMINDER_WORKER_CONCURRENCY=3
NOTIFICATION_WORKER_CONCURRENCY=5
ANALYTICS_WORKER_CONCURRENCY=2

# ── Monitoring & Error Tracking ───────────────────────────────────────────────
# SENTRY_DSN=https://xxxx@sentry.io/yyyy

# ── Security ──────────────────────────────────────────────────────────────────
# Comma-separated list of IPs allowed to access /admin/queues
# Leave empty to allow all authenticated admins
# ADMIN_IP_WHITELIST=127.0.0.1,10.0.0.1

# ── Caching / Startup ─────────────────────────────────────────────────────────
CACHE_WARM_ON_STARTUP=true
CACHE_TTL_SECONDS=300             # How long cache entries live (default: 5 min)

# ── Backup & Restore (used by scripts/backup.sh) ─────────────────────────────
# S3_BACKUP_BUCKET=your-backup-bucket-name
# BACKUP_ENCRYPTION_KEY=a-very-long-random-string-at-least-32-chars
# BACKUP_RETENTION_DAYS=30

# Optional: separate DB for restore drills (defaults to MONGO_URI if not set)
# RESTORE_MONGO_URI=mongodb://localhost:27017/qline_restore_test

# ── Medical Record Encryption ─────────────────────────────────────────────────
# Used by mongoose-field-encryption for sensitive fields
# MEDICAL_ENCRYPTION_KEY=32-char-hex-key-for-field-level-encryption
