{
  "name": "qline-backend",
  "version": "1.0.0",
  "description": "Qline OPD Queue and Appointment Management System - Backend",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "worker": "node workers/index.js",
    "test": "node -e \"const cp=require('child_process');let cmd='node --test';try{require.resolve('jest/bin/jest');cmd='jest --detectOpenHandles --forceExit --passWithNoTests';}catch{}const run=cp.spawnSync(cmd,{stdio:'inherit',shell:true});process.exit(run.status ?? 1);\"",
    "db:optimize": "node -e \"require('./utils/dbOptimizer').ensureIndexes().then(() => { console.log('Done'); process.exit(0); }).catch(e => { console.error(e); process.exit(1); })\"",
    "backup": "bash scripts/backup.sh",
    "restore-drill": "node scripts/restore-drill.js"
  },
  "keywords": [
    "opd",
    "queue",
    "appointment",
    "hospital",
    "healthcare"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@bull-board/api": "^6.18.2",
    "@bull-board/express": "^6.18.2",
    "@sendgrid/mail": "^8.1.6",
    "@sentry/node": "^10.39.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "aws-sdk": "^2.1693.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.69.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "mongoose-field-encryption": "^7.0.1",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "rate-limit-redis": "^4.3.1",
    "redlock": "^5.0.0-beta.2",
    "socket.io": "^4.6.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
