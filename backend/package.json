{
  "name": "qline-backend",
  "version": "2.0.0",
  "description": "Qline OPD Queue and Appointment Management System — MongoDB-only (no Redis, no Docker)",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "worker": "node workers/index.js",
    "test": "node --test \"tests/**/*.test.js\"",
    "db:optimize": "node -e \"require('./utils/dbOptimizer').ensureIndexes().then(() => { console.log('Done'); process.exit(0); }).catch(e => { console.error(e); process.exit(1); })\"",
    "seed": "node setup-demo-data.js"
  },
  "keywords": [
    "opd",
    "queue",
    "appointment",
    "hospital",
    "healthcare"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "@sentry/node": "^10.39.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "mongoose-field-encryption": "^7.0.1",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "socket.io": "^4.6.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  }
}