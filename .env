# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/qline

# JWT Configuration
JWT_SECRET=qline_super_secret_jwt_key_dev_2026
JWT_EXPIRY=15m

# Refresh Token Configuration
JWT_REFRESH_SECRET=qline_super_secret_refresh_key_dev_2026
JWT_REFRESH_EXPIRY=7d

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Redis Configuration (Phase 4)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Redis Production Config (Phase 4.1)
REDIS_MAX_MEMORY=256mb
REDIS_EVICTION_POLICY=allkeys-lru
REQUIRE_REDIS_IN_PRODUCTION=true

# Medical Record Encryption (Phase 4.1)
# CRITICAL: Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER commit this key to version control
# Rotate every 90 days in production
MEDICAL_RECORD_ENCRYPTION_KEY=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1

# Email Configuration (Phase 4) - SendGrid
SENDGRID_API_KEY=
FROM_EMAIL=noreply@qline.com

# Email Configuration (Phase 4) - SMTP Fallback
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Email Retry Configuration (Phase 4.1)
EMAIL_MAX_RETRY_ATTEMPTS=3
EMAIL_RETRY_DELAY_MS=60000

# Rate Limiting (development vs production)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Sentry (Phase 4) - Error Monitoring
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Rate Limiting (Phase 4)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging (Phase 4)
LOG_LEVEL=info
LOG_MEDICAL_DATA=false
